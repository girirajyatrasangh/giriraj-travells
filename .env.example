# ─────────────────────────────────────────────────────────────────────────────
#  Giriraj Travells — Environment Variables Template
#  Copy this file to .env.local and fill in real values.
#  .env.local is gitignored — NEVER commit real credentials to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required for booking persistence) ───────────────────────────────
#  Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

#  Service role key — SERVER-SIDE ONLY (never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Contact Information ────────────────────────────────────────────────────────
NEXT_PUBLIC_PHONE=+91XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX
NEXT_PUBLIC_EMAIL=your@email.com

# ── Site URL (used in sitemap and Open Graph) ─────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.your-domain.com
